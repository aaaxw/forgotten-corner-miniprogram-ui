<view class="page profile-page">
  <view class="profile-card hero-card">
    <view class="profile-avatar">秦</view>
    <view class="profile-info">
      <view class="profile-name">{{user.name}}</view>
      <view class="profile-meta">{{user.verified ? '学生认证' : '未认证'}} · {{user.school}}</view>
    </view>
  </view>

  <view class="score-panel">
    <view class="score-item">
      <view class="score-num">{{stats.points}}</view>
      <view class="score-label">守护积分</view>
    </view>
    <view class="score-item">
      <view class="score-num">{{stats.published}}</view>
      <view class="score-label">发布记录</view>
    </view>
    <view class="score-item">
      <view class="score-num">{{stats.completed}}</view>
      <view class="score-label">成功归还</view>
    </view>
    <view class="score-item">
      <view class="score-num">{{stats.active}}</view>
      <view class="score-label">进行中</view>
    </view>
  </view>

  <view class="section-head">
    <view class="section-title">最近发布</view>
    <navigator class="section-link" url="/pages/publish/publish" open-type="switchTab">继续发布</navigator>
  </view>
  <view wx:if="{{recentRecords.length === 0}}" class="empty-card">暂无发布记录</view>
  <view wx:for="{{recentRecords}}" wx:key="id" class="panel record-card" data-id="{{item.id}}" bindtap="goDetail">
    <view class="record-left">
      <view class="record-type {{item.type}}">{{item.typeText}}</view>
      <view>
        <view class="record-title">{{item.title}}</view>
        <view class="record-meta">{{item.place}} · {{item.time}}</view>
      </view>
    </view>
    <view class="record-status">{{item.status}}</view>
  </view>

  <view class="section-title">常用功能</view>
  <view class="panel action-list">
    <view wx:for="{{actions}}" wx:key="title" class="action-row" data-title="{{item.title}}" bindtap="tapAction">
      <view>
        <view class="action-title">{{item.title}}</view>
        <view class="action-desc">{{item.desc}}</view>
      </view>
      <view class="arrow">›</view>
    </view>
    <view class="action-row reset-row" bindtap="clearDemoData">
      <view>重置演示数据</view>
      <view class="arrow">↻</view>
    </view>
  </view>
</view>
