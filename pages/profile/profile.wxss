.profile-card {
  display: flex;
  align-items: center;
  gap: 26rpx;
  padding: 36rpx;
}

.profile-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 116rpx;
  height: 116rpx;
  border-radius: 38rpx;
  color: #fffdf5;
  font-size: 48rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #166b5f, #ffc356);
}

.profile-name {
  font-size: 38rpx;
  font-weight: 900;
}

.profile-meta {
  margin-top: 12rpx;
  color: #7c7a70;
  font-size: 25rpx;
}

.score-panel {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18rpx;
  margin-top: 24rpx;
}

.score-item {
  padding: 24rpx 6rpx;
  border-radius: 30rpx;
  text-align: center;
  background: #fffdf5;
}

.score-num {
  color: #166b5f;
  font-size: 34rpx;
  font-weight: 900;
}

.score-label {
  margin-top: 8rpx;
  color: #7c7a70;
  font-size: 22rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 38rpx 0 20rpx;
}

.section-head .section-title {
  margin: 0;
}

.section-link {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: #166b5f;
  font-size: 23rpx;
  font-weight: 800;
  background: #e8f5ef;
}

.record-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
  padding: 26rpx;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.record-type {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border-radius: 26rpx;
  color: #fffdf5;
  font-size: 23rpx;
  font-weight: 900;
}

.record-type.lost {
  background: #e9873d;
}

.record-type.found {
  background: #2da995;
}

.record-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 29rpx;
  font-weight: 900;
}

.record-meta {
  overflow: hidden;
  margin-top: 8rpx;
  color: #7c7a70;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 23rpx;
}

.record-status {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #166b5f;
  font-size: 22rpx;
  font-weight: 800;
  background: #e8f5ef;
}

.action-list {
  overflow: hidden;
}

.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 30rpx;
  border-bottom: 2rpx solid #f0ead8;
}

.action-row:last-child {
  border-bottom: 0;
}

.action-title {
  font-size: 30rpx;
  font-weight: 900;
}

.action-desc {
  margin-top: 8rpx;
  color: #7c7a70;
  font-size: 23rpx;
  font-weight: 500;
}

.arrow {
  color: #a9a59a;
  font-size: 44rpx;
}

.reset-row {
  color: #c06c37;
}

.empty-card {
  padding: 36rpx 24rpx;
  border-radius: 30rpx;
  color: #7c7a70;
  text-align: center;
  background: rgba(255, 253, 245, 0.82);
}
