.msg-hero {
  padding: 38rpx 34rpx;
  background: linear-gradient(135deg, #243633, #166b5f);
}

.msg-title {
  color: #fffdf5;
  font-size: 48rpx;
  font-weight: 900;
}

.msg-desc {
  margin-top: 16rpx;
  color: rgba(255, 253, 245, 0.78);
  font-size: 27rpx;
  line-height: 1.6;
}

.msg-stat {
  display: inline-flex;
  align-items: baseline;
  gap: 10rpx;
  margin-top: 26rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  color: #fffdf5;
  background: rgba(255, 253, 245, 0.16);
}

.msg-stat-num {
  font-size: 34rpx;
  font-weight: 900;
}

.msg-stat-label {
  font-size: 24rpx;
  font-weight: 700;
}

.message-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 38rpx 0 20rpx;
}

.message-toolbar .section-title {
  margin: 0;
}

.toolbar-actions {
  display: flex;
  gap: 12rpx;
}

.toolbar-btn {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: #166b5f;
  font-size: 23rpx;
  font-weight: 800;
  background: #e8f5ef;
}

.toolbar-btn.danger {
  color: #c06c37;
  background: #fff0df;
}

.message-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-bottom: 18rpx;
  padding: 26rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  border-radius: 30rpx;
  color: #fffdf5;
  font-size: 32rpx;
  font-weight: 900;
  background: #e9873d;
}

.message-main {
  flex: 1;
}

.message-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.message-name {
  font-size: 30rpx;
  font-weight: 900;
}

.message-time,
.message-text {
  color: #7c7a70;
  font-size: 24rpx;
}

.message-text {
  margin-top: 10rpx;
}

.dot {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e94747;
}

.empty-card {
  padding: 44rpx 24rpx;
  border-radius: 30rpx;
  color: #7c7a70;
  text-align: center;
  background: rgba(255, 253, 245, 0.82);
}

.empty-title {
  color: #243633;
  font-size: 31rpx;
  font-weight: 900;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.55;
}

.empty-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 26rpx;
  width: 180rpx;
  height: 70rpx;
  border-radius: 999rpx;
  color: #fffdf5;
  font-size: 26rpx;
  font-weight: 800;
  background: #166b5f;
}
