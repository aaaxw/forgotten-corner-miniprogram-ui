<view class="page home-page">
  <view class="hero-card hero">
    <view class="eyebrow">Lost & Found Campus</view>
    <view class="hero-title">让遗失物品，回到正确的人手里</view>
    <view class="hero-desc">发布寻物、浏览招领、智能匹配，校园里的每个角落都有人守护。</view>
    <view class="hero-actions">
      <navigator class="primary-btn hero-btn" url="/pages/publish/publish" open-type="switchTab">立即发布</navigator>
      <navigator class="secondary-btn hero-btn" url="/pages/messages/messages" open-type="switchTab">查看线索</navigator>
    </view>
  </view>

  <view class="stats">
    <view class="stat-card">
      <view class="stat-num">{{stats.total}}</view>
      <view class="stat-label">本月发布</view>
    </view>
    <view class="stat-card">
      <view class="stat-num">{{stats.foundRate}}</view>
      <view class="stat-label">找回率</view>
    </view>
    <view class="stat-card">
      <view class="stat-num">{{stats.response}}</view>
      <view class="stat-label">平均响应</view>
    </view>
  </view>

  <view class="search-panel">
    <view class="search-icon">⌕</view>
    <input bindinput="onSearch" placeholder="搜索物品、地点或关键词" placeholder-class="placeholder" />
  </view>

  <view class="quick-row">
    <view
      wx:for="{{quickFilters}}"
      wx:key="value"
      class="quick-pill {{scope === item.value ? 'active' : ''}}"
      data-scope="{{item.value}}"
      bindtap="switchScope"
    >{{item.label}}</view>
  </view>

  <scroll-view class="category-scroll" scroll-x>
    <view class="category-row">
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        class="category {{selected === index ? 'active' : ''}}"
        data-index="{{index}}"
        bindtap="selectCategory"
      >{{item}}</view>
    </view>
  </scroll-view>

  <view class="section-title">最近动态</view>
  <view wx:if="{{items.length === 0}}" class="empty-card">
    <view class="empty-title">暂无匹配线索</view>
    <view class="empty-desc">换个关键词，或去发布一条新的寻物/招领信息。</view>
    <navigator class="empty-action" url="/pages/publish/publish" open-type="switchTab">去发布</navigator>
  </view>
  <view wx:for="{{items}}" wx:key="id" class="item-card lost-card" data-id="{{item.id}}" bindtap="goDetail">
    <view wx:if="{{item.image}}" class="item-photo">
      <image src="{{item.image}}" mode="aspectFill" />
    </view>
    <view wx:else class="item-mark {{item.color}}">{{item.typeText}}</view>
    <view class="item-main">
      <view class="item-head">
        <view class="item-title">{{item.title}}</view>
        <view class="item-type {{item.type}}">{{item.typeText}}</view>
      </view>
      <view class="item-meta">{{item.place}} · {{item.time}}</view>
      <view class="item-desc">{{item.desc}}</view>
    </view>
    <view class="item-tag">{{item.status}}</view>
  </view>
</view>
