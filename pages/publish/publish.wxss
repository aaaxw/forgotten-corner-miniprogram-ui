.publish-head {
  padding: 18rpx 6rpx 28rpx;
}

.head-title {
  font-size: 52rpx;
  font-weight: 900;
}

.head-desc {
  margin-top: 16rpx;
  color: #66716e;
  font-size: 27rpx;
  line-height: 1.65;
}

.mode-tabs {
  display: flex;
  gap: 18rpx;
  margin: 10rpx 0 24rpx;
}

.mode {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 28rpx;
  color: #66716e;
  text-align: center;
  font-size: 30rpx;
  font-weight: 800;
  background: rgba(255, 253, 245, 0.76);
}

.mode.active {
  color: #fffdf5;
  background: #166b5f;
  box-shadow: 0 16rpx 30rpx rgba(22, 107, 95, 0.2);
}

.form-panel {
  padding: 30rpx;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  margin-bottom: 14rpx;
  color: #243633;
  font-size: 27rpx;
  font-weight: 900;
}

input,
textarea,
.picker-value {
  width: 100%;
  box-sizing: border-box;
  border-radius: 24rpx;
  color: #243633;
  background: #f2f4e8;
}

input {
  height: 84rpx;
  padding: 0 24rpx;
}

.picker-value {
  height: 84rpx;
  padding: 0 24rpx;
  line-height: 84rpx;
}

textarea {
  height: 180rpx;
  padding: 22rpx 24rpx;
}

.placeholder {
  color: #a9a59a;
}

.upload-section {
  margin-top: 6rpx;
}

.upload-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  color: #243633;
  font-size: 27rpx;
  font-weight: 900;
}

.upload-title text {
  color: #a06e43;
  font-size: 23rpx;
  font-weight: 700;
}

.upload-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.upload-box,
.photo-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 176rpx;
  border-radius: 28rpx;
}

.upload-box {
  flex-direction: column;
  gap: 6rpx;
  border: 3rpx dashed #9acfc4;
  color: #166b5f;
  background: #edf8f4;
}

.upload-plus {
  line-height: 1;
  font-size: 52rpx;
  font-weight: 300;
}

.upload-text {
  font-size: 24rpx;
  font-weight: 800;
}

.photo-cell {
  position: relative;
  overflow: hidden;
  background: #f2f4e8;
}

.photo-cell image {
  width: 100%;
  height: 100%;
}

.photo-remove {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  color: #fffdf5;
  font-size: 32rpx;
  line-height: 1;
  background: rgba(36, 54, 51, 0.72);
}

.submit-btn {
  margin-top: 30rpx;
  width: 100%;
  border: 0;
  padding: 0;
}
